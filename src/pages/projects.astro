---
import Layout from "@/layouts/Layout.astro";

const projects = [
  {
    title: "DL - Differential-Linear Cryptanalysis",
    description: "Implementation of differential-linear attacks from a boomerang perspective with applications to multiple ciphers including AES, Ascon, CLEFIA, SKINNY, and others.",
    technologies: ["Python", "SageMath", "Cryptanalysis"],
    github: "https://github.com/hadipourh/DL",
    paper: "https://ia.cr/2024/255",
    status: "Active",
    year: "2024",
    featured: true
  },
  {
    title: "ZeroPlus - Improved Structural Attack Search",
    description: "Advanced automated search methods for integral, impossible-differential and zero-correlation attacks with applications to modern ciphers.",
    technologies: ["Python", "Constraint Programming", "MILP"],
    github: "https://github.com/hadipourh/zeroplus",
    paper: "https://ia.cr/2023/1701",
    status: "Active",
    year: "2024",
    featured: true
  },
  {
    title: "QARMAnalysis - Cryptanalysis of QARMAv2",
    description: "Comprehensive cryptanalytic toolkit for the QARMAv2 tweakable block cipher including impossible differential and integral attacks.",
    technologies: ["Python", "SageMath", "SAT Solving"],
    github: "https://github.com/hadipourh/QARMAnalysis",
    paper: "https://ia.cr/2023/1833",
    status: "Complete",
    year: "2024",
    featured: true
  },
  {
    title: "Zero - Finding the Impossible",
    description: "Unified framework for automated search of impossible-differential, zero-correlation, and integral attacks on symmetric-key primitives.",
    technologies: ["Python", "Constraint Programming", "Automated Search"],
    github: "https://github.com/hadipourh/zero",
    paper: "https://ia.cr/2022/1147",
    status: "Complete",
    year: "2023",
    featured: true
  },
  {
    title: "Comeback - Boomerang Attacks on Feistel Structures",
    description: "Implementation of boomerang attacks on Feistel structures with applications to CLEFIA, WARP, LBlock, LBlock-s and TWINE.",
    technologies: ["Python", "SageMath", "Boomerang Attacks"],
    github: "https://github.com/hadipourh/comeback",
    paper: "https://ia.cr/2022/745",
    status: "Complete",
    year: "2023",
    featured: false
  },
  {
    title: "MPT - Monomial Prediction Tool",
    description: "Tool for integral cryptanalysis based on monomial prediction with detailed analysis of the WARP block cipher.",
    technologies: ["Python", "SageMath", "Monomial Prediction"],
    github: "https://github.com/hadipourh/mpt",
    paper: "https://ia.cr/2022/729",
    status: "Complete", 
    year: "2023",
    featured: false
  },
  {
    title: "FaultyAES - Multiple Persistent Fault Analysis",
    description: "Practical implementation of multiple persistent fault attacks on AES with comprehensive analysis tools.",
    technologies: ["Python", "Fault Injection", "AES"],
    github: "https://github.com/hadipourh/faultyaes",
    paper: "https://tches.iacr.org/index.php/TCHES/article/view/9301",
    status: "Complete",
    year: "2022",
    featured: false
  },
  {
    title: "Autoguess - Guess-and-Determine Attack Tool",
    description: "Automated tool for finding guess-and-determine attacks and key bridges in symmetric-key cryptographic primitives.",
    technologies: ["Python", "Constraint Programming", "Graph Theory"],
    github: "https://github.com/hadipourh/autoguess",
    paper: "https://eprint.iacr.org/2021/1529",
    status: "Complete",
    year: "2022",
    featured: true
  },
  {
    title: "Boomerang - Rectangle Attack Framework",
    description: "Framework for improved rectangle attacks on SKINNY and CRAFT using automated search techniques.",
    technologies: ["Python", "SageMath", "Rectangle Attacks"],
    github: "https://github.com/hadipourh/Boomerang",
    paper: "https://tosc.iacr.org/index.php/ToSC/article/view/8908",
    status: "Complete",
    year: "2022",
    featured: false
  },
  {
    title: "CraftAnalysis - Comprehensive CRAFT Analysis",
    description: "Complete security analysis toolkit for the CRAFT block cipher including differential, linear, and impossible differential attacks.",
    technologies: ["Python", "SageMath", "Comprehensive Analysis"],
    github: "https://github.com/hadipourh/craftanalysis",
    paper: "https://tosc.iacr.org/index.php/ToSC/article/view/8466",
    status: "Complete",
    year: "2020",
    featured: false
  }
];

const featuredProjects = projects.filter(project => project.featured);
const otherProjects = projects.filter(project => !project.featured);
---

<Layout title="Projects">
  <div class="prose max-w-none">
    <h1 class="text-3xl font-bold mb-8">Research Projects & Tools</h1>
    
    <p class="text-lg mb-8 text-base-content/80">
      A collection of open-source cryptanalytic tools and research implementations. 
      These projects span various areas of symmetric-key cryptography including automated attack search, 
      constraint programming applications, and practical cryptanalytic techniques.
    </p>

    <!-- Featured Projects -->
    <h2 class="text-2xl font-bold mb-6">Featured Projects</h2>
    <div class="grid gap-6 mb-12">
      {
        featuredProjects.map((project) => (
          <div class="card bg-base-200 shadow-lg">
            <div class="card-body">
              <div class="flex justify-between items-start mb-3">
                <div class="flex gap-2">
                  <div class="badge badge-primary">{project.year}</div>
                  <div class={`badge ${project.status === 'Active' ? 'badge-success' : 'badge-info'}`}>
                    {project.status}
                  </div>
                </div>
              </div>
              
              <h3 class="card-title text-xl mb-3">{project.title}</h3>
              
              <p class="text-base text-base-content/80 mb-4">{project.description}</p>
              
              <div class="flex flex-wrap gap-2 mb-4">
                {project.technologies.map((tech) => (
                  <span class="badge badge-outline badge-sm">{tech}</span>
                ))}
              </div>
              
              <div class="card-actions justify-end gap-2">
                <a href={project.github} class="btn btn-sm btn-primary" target="_blank" rel="noopener">
                  <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                  GitHub
                </a>
                
                {project.paper && (
                  <a href={project.paper} class="btn btn-sm btn-secondary" target="_blank" rel="noopener">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                    </svg>
                    Paper
                  </a>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>

    <!-- Other Projects -->
    <h2 class="text-2xl font-bold mb-6">Other Projects</h2>
    <div class="grid md:grid-cols-2 gap-4">
      {
        otherProjects.map((project) => (
          <div class="card bg-base-300 compact">
            <div class="card-body">
              <div class="flex justify-between items-center mb-2">
                <div class="badge badge-sm badge-outline">{project.year}</div>
                <div class={`badge badge-sm ${project.status === 'Active' ? 'badge-success' : 'badge-info'}`}>
                  {project.status}
                </div>
              </div>
              
              <h3 class="card-title text-lg">{project.title}</h3>
              
              <p class="text-sm text-base-content/70 mb-3">{project.description}</p>
              
              <div class="flex flex-wrap gap-1 mb-3">
                {project.technologies.slice(0, 3).map((tech) => (
                  <span class="badge badge-outline badge-xs">{tech}</span>
                ))}
                {project.technologies.length > 3 && (
                  <span class="badge badge-outline badge-xs">+{project.technologies.length - 3}</span>
                )}
              </div>
              
              <div class="card-actions justify-end">
                <a href={project.github} class="btn btn-xs btn-primary" target="_blank" rel="noopener">
                  GitHub
                </a>
                {project.paper && (
                  <a href={project.paper} class="btn btn-xs btn-secondary" target="_blank" rel="noopener">
                    Paper
                  </a>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>
    
    <div class="mt-8 p-4 bg-base-300 rounded-lg">
      <p class="text-sm text-base-content/70">
        All projects are open-source and available on 
        <a href="https://github.com/hadipourh" class="link link-primary" target="_blank" rel="noopener">
          GitHub
        </a>. 
        Contributions, issues, and feedback are welcome!
      </p>
    </div>
  </div>
</Layout>
