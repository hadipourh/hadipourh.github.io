---

<Layout title="Talks">
  <div class="prose max-w-none">
    <h1 class="text-3xl font-bold mb-8">Conference Talks & Presentations</h1>
    
    <p class="text-lg mb-8 text-base-content/80">
      A collection of my research presentations at international conferences, workshops, and academic venues. 
      All presentation materials including slides, videos, and related code are available through the provided links.
    </p>

    <div class="space-y-6">
      {
        talks.map((talk, index) => (
          <div class="card bg-base-200 shadow-lg">
            <div class="card-body">
              <div class="flex justify-between items-start mb-3">
                <div class="badge badge-primary">{talk.venue}</div>
                <div class="text-sm text-base-content/60">{talk.date}</div>
              </div>
              
              <h2 class="card-title text-lg mb-2">{talk.title}</h2>
              
              <div class="flex items-center gap-2 mb-3">
                <svg class="w-4 h-4 text-base-content/60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <span class="text-sm text-base-content/70">{talk.location}</span>
              </div>
              
              <p class="text-sm text-base-content/80 mb-4">{talk.description}</p>
              
              <div class="card-actions justify-start gap-2 flex-wrap">
                <a href={talk.slides} class="btn btn-sm btn-primary" target="_blank" rel="noopener">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                  Slides
                </a>
                
                {talk.paper && (
                  <a href={talk.paper} class="btn btn-sm btn-secondary" target="_blank" rel="noopener">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
                    </svg>
                    Paper
                  </a>
                )}
                
                {talk.video && (
                  <a href={talk.video} class="btn btn-sm btn-accent" target="_blank" rel="noopener">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h1.586a1 1 0 01.707.293l2.414 2.414a1 1 0 00.707.293H15"/>
                    </svg>
                    Video
                  </a>
                )}
                
                {talk.code && (
                  <a href={talk.code} class="btn btn-sm btn-info" target="_blank" rel="noopener">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                    </svg>
                    Code
                  </a>
                )}
              </div>
            </div>
          </div>
        ))
      }
    </div>
    
    <div class="mt-8 p-4 bg-base-300 rounded-lg">
      <p class="text-sm text-base-content/70">
        All talk materials are available in my 
        <a href="https://github.com/hadipourh/talks" class="link link-primary" target="_blank" rel="noopener">
          GitHub talks repository
        </a>. 
        Feel free to reuse the LaTeX sources for your own presentations.
      </p>
    </div>
  </div>
</Layout>
