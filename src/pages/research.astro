---
import Layout from "@/layouts/Layout.astro";
import { profile } from "@/settings";
import BetterIcon from "@/components/ui/BetterIcon.astro";
import List from "@/components/ui/List.astro";
import {RESEARCH_ICONS} from "@/data/researchIcons";

const { research_areas } = profile;
---

<Layout title="Research | Hosein Hadipour">
  <div class="prose max-w-none">
    <h1 class="text-3xl font-bold mb-8">Research Statement</h1>

    <div class="mb-12">
      <p class="text-lg mb-6">
        My research focuses on developing automated methods for cryptanalysis of symmetric-key cryptographic primitives. Through innovative application of constraint programming, SAT solving, and mixed-integer linear programming, I aim to advance the state-of-the-art in cryptanalytic techniques and contribute to the security assessment of modern cryptographic algorithms.
      </p>
      <p class="text-lg mb-6">
        This interdisciplinary approach combines theoretical cryptography with computational methods, leading to practical tools and techniques that can evaluate the security of block ciphers, stream ciphers, and other cryptographic primitives against various attack vectors.
      </p>
    </div>

    <h2 class="text-2xl font-bold mb-6">Research Areas</h2>
    <div class="grid gap-8 mb-12">
      {
        research_areas.map((area) => (
          <div class="flex gap-6 items-start">
            <BetterIcon>
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke-width="2"
                class="size-6 stroke-accent"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d={RESEARCH_ICONS[area.field as keyof typeof RESEARCH_ICONS]?.path || RESEARCH_ICONS['computer-science'].path}
                />
              </svg>
            </BetterIcon>
            <div>
              <h3 class="text-xl font-semibold mb-2">{area.title}</h3>
              <p class="text-base">{area.description}</p>
            </div>
          </div>
        ))
      }
    </div>

    <List listTitle="Current Projects" listItems={[
      {
        title: "Automated Cryptanalysis Tools",
        description: "Development of automated tools for finding differential, linear, and integral attacks on block ciphers using constraint programming and SAT solving."
      },
      {
        title: "ARX Cipher Analysis",
        description: "Specialized techniques for analyzing Addition-Rotation-XOR (ARX) based ciphers including SIMON, SPECK, and Salsa20 families."
      },
      {
        title: "Machine Learning in Cryptanalysis",
        description: "Exploring the application of machine learning techniques to improve traditional cryptanalytic methods and discover new attack vectors."
      },
      {
        title: "Side-Channel Security",
        description: "Analysis of implementation security including fault attacks and timing-based attacks on cryptographic algorithms."
      }
    ]} />

    <h2 class="text-2xl font-bold mb-6">Research Impact</h2>
    <p class="text-lg mb-6">
      My research contributes to the security evaluation of modern cryptographic systems by providing automated tools and novel attack techniques. The work has practical implications for the design and standardization of new cryptographic algorithms, helping ensure they resist known attack methods before deployment in real-world applications.
    </p>
  </div>
</Layout>
